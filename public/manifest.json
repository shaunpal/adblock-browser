{
  "manifest_version": 3,
  "name": "My Ad Blocker",
  "version": "1.0",
  "description": "Simple ad blocker",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icons/icon.png"
  }
}